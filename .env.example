APP_NAME="Silver Academy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (Supabase PostgreSQL)
# Get these values from your Supabase project Settings > Database
DB_CONNECTION=pgsql
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# For Supabase, you can also use the connection string:
# DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Session vs. URLs: there is NO conflict between login and student/parent code features ---
# SESSION_DOMAIN = only controls which domain the SESSION COOKIE is sent to (login, add student, etc.).
#   Set to null so the cookie works on the domain users actually visit (e.g. silveracademypa.org).
#   Do NOT set it to a different domain (e.g. silveracademy.org) or login and form submissions will fail.
# APP_URL = used when generating links IN EMAILS (login link, password reset, parent code invite).
#   Set to your real site URL (e.g. https://silveracademypa.org).
# Parent/student code generation does NOT use the session cookie; it uses the database. The same
#   session cookie is required for both "login" and "add student" — use SESSION_DOMAIN=null.
# Production: set APP_URL and SESSION_SECURE_COOKIE=true; keep SESSION_DOMAIN=null.
# If login or "Add Student" fails (page refreshes back), fix SESSION_DOMAIN (set to null), then config:clear.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: "log" writes to storage/logs/laravel.log (no real email). Use "smtp" to send (e.g. password reset).
# For dev with real inbox: set MAIL_MAILER=smtp and use Mailtrap, or SendGrid SMTP below.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
# SendGrid SMTP (optional): use smtp.sendgrid.net, port 587, username "apikey", password = SENDGRID_API_KEY
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=${SENDGRID_API_KEY}
MAIL_FROM_ADDRESS="hello@silveracademy.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
